DISCORD_TOKEN=
GEMINI_API_KEY=

# Discord channel names
UNRESTRICTED_CHANNEL_NAME=制限なし投稿
MODERATED_CHANNEL_NAME=投稿
SYSTEM_CHANNEL_NAME=システム

# APU専用のXブラウザプロファイル。kyohi-chan側のFirefoxプロファイルとは分ける。
X_BROWSER_CHANNEL=chrome
X_PROFILE_DIR=.x-profile-apu

# Queue behavior
POST_INTERVAL_MINUTES=10
POST_INTERVAL_JITTER_MINUTES=1

# Daily report time in Asia/Tokyo
DAILY_REPORT_HOUR=23
DAILY_REPORT_MINUTE=59

# Gemini model. Cheap text moderation candidate as of 2026-05-28.
GEMINI_MODEL=gemini-2.5-flash-lite-preview-09-2025
